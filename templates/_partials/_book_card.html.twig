<div class="book-card">
    <a href="{{ path('app_book_show', {slug: book.slug}) }}" class="text-decoration-none">
        {% if book.coverImage %}
            <div class="card-img-wrap">
                <img src="{{ asset('uploads/covers/' ~ book.coverImage) }}" alt="{{ book.title }}">
            </div>
        {% else %}
            <div class="card-img-placeholder">📖</div>
        {% endif %}
    </a>
    <div class="card-body">
        <a href="{{ path('app_book_show', {slug: book.slug}) }}" class="text-decoration-none text-reset">
            <h5 class="card-title">{{ book.title }}</h5>
        </a>
        <p class="card-author">{{ book.author }}</p>
        {% if book.averageRating %}
            <div class="star-rating mb-2">
                {% for i in 1..5 %}
                    <span class="{{ i <= book.averageRating|round ? '' : 'star-empty' }}">&#9733;</span>
                {% endfor %}
                <small class="text-muted ms-1" style="font-size: 0.75rem;">({{ book.reviews|length }})</small>
            </div>
        {% endif %}
        <div class="mt-auto">
            {% if book.availableCopies > 0 %}
                <span class="availability-tag available">Disponible</span>
            {% else %}
                <span class="availability-tag unavailable">Indisponible</span>
            {% endif %}
        </div>
    </div>
</div>
