<div class="card book-card">
    {% if book.coverImage %}
        <img src="{{ asset('uploads/covers/' ~ book.coverImage) }}" class="card-img-top" alt="{{ book.title }}">
    {% else %}
        <div class="card-img-placeholder text-muted">📖</div>
    {% endif %}
    <div class="card-body d-flex flex-column">
        <h5 class="card-title">{{ book.title }}</h5>
        <p class="card-text text-muted mb-1">{{ book.author }}</p>
        {% if book.averageRating %}
            <div class="star-rating mb-2">
                {% for i in 1..5 %}
                    <span class="{{ i <= book.averageRating|round ? '' : 'star-empty' }}">&#9733;</span>
                {% endfor %}
                <small class="text-muted">({{ book.reviews|length }})</small>
            </div>
        {% endif %}
        <div class="mt-auto">
            {% if book.availableCopies > 0 %}
                <span class="badge bg-success mb-2">Disponible</span>
            {% else %}
                <span class="badge bg-danger mb-2">Indisponible</span>
            {% endif %}
            <a href="{{ path('app_book_show', {slug: book.slug}) }}" class="btn btn-outline-primary btn-sm w-100">Voir le détail</a>
        </div>
    </div>
</div>
