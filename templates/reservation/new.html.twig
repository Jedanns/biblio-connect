{% extends 'base.html.twig' %}

{% block title %}Réserver {{ book.title }} - BiblioConnect{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-8">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="{{ path('app_book_index') }}">Catalogue</a></li>
                <li class="breadcrumb-item"><a href="{{ path('app_book_show', {slug: book.slug}) }}">{{ book.title }}</a></li>
                <li class="breadcrumb-item active">Réserver</li>
            </ol>
        </nav>

        <div class="card">
            <div class="card-body">
                <h2>Réserver : {{ book.title }}</h2>
                <p class="text-muted">par {{ book.author.fullName }}</p>
                <p>
                    <span class="text-success fw-bold">{{ book.availableCopies }} exemplaire(s) disponible(s)</span>
                </p>

                <hr>

                {{ form_start(form) }}
                    <div class="row">
                        <div class="col-md-6">
                            {{ form_row(form.startDate) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.endDate) }}
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary">Confirmer la réservation</button>
                    <a href="{{ path('app_book_show', {slug: book.slug}) }}" class="btn btn-outline-secondary ms-2">Annuler</a>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
