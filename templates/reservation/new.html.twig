{% extends 'base.html.twig' %}

{% block title %}Réserver {{ book.title }} — BiblioConnect{% endblock %}

{% block body %}
<a href="{{ path('app_book_show', {slug: book.slug}) }}" class="btn btn-editorial-ghost mb-4" style="font-size: 0.85rem;">
    <span style="margin-right: 0.5rem;">&larr;</span> Retour à l'ouvrage
</a>

<div style="max-width: 600px;">
    <span class="editorial-label">Réservation</span>
    <h1 class="mt-2" style="font-size: 1.75rem;">{{ book.title }}</h1>
    <p style="font-family: var(--font-display); font-style: italic; color: var(--color-text-soft);">
        par {{ book.author.fullName }}
    </p>
    <p>
        <span class="availability-tag available">{{ book.availableCopies }} exemplaire{{ book.availableCopies > 1 ? 's' : '' }} disponible{{ book.availableCopies > 1 ? 's' : '' }}</span>
    </p>

    <hr class="editorial-divider">

    {{ form_start(form) }}
        <div class="row g-3">
            <div class="col-md-6">
                {{ form_row(form.startDate) }}
            </div>
            <div class="col-md-6">
                {{ form_row(form.endDate) }}
            </div>
        </div>
        <div class="d-flex gap-3 mt-4">
            <button type="submit" class="btn btn-editorial btn-editorial-primary">Confirmer</button>
            <a href="{{ path('app_book_show', {slug: book.slug}) }}" class="btn btn-editorial btn-editorial-outline">Annuler</a>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}
