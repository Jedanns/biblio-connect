{% extends 'base.html.twig' %}

{% block title %}Mes favoris — BiblioConnect{% endblock %}

{% block body %}
<span class="editorial-label">Espace personnel</span>
<h1 class="mt-2">Mes favoris</h1>
<hr class="editorial-divider">

{% if favorites|length > 0 %}
<div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
    {% for favorite in favorites %}
        <div class="col">
            {% include '_partials/_book_card.html.twig' with {book: favorite.book} %}
        </div>
    {% endfor %}
</div>
{% else %}
    <p class="text-muted" style="font-style: italic;">Vous n'avez pas encore de favoris.</p>
    <a href="{{ path('app_book_index') }}" class="btn btn-editorial btn-editorial-outline mt-2">Parcourir le catalogue</a>
{% endif %}
{% endblock %}
