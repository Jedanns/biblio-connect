{% extends 'base.html.twig' %}

{% block title %}Mes favoris - BiblioConnect{% endblock %}

{% block body %}
<h1>Mes favoris</h1>

{% if favorites|length > 0 %}
<div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
    {% for favorite in favorites %}
        <div class="col">
            {% include '_partials/_book_card.html.twig' with {book: favorite.book} %}
        </div>
    {% endfor %}
</div>
{% else %}
    <div class="alert alert-info">
        Vous n'avez pas encore de favoris.
        <a href="{{ path('app_book_index') }}">Parcourir le catalogue</a>
    </div>
{% endif %}
{% endblock %}
