{% extends 'base.html.twig' %}

{% block title %}Mon profil - BiblioConnect{% endblock %}

{% block body %}
<h1>Mon profil</h1>
<p class="lead">Bienvenue, {{ app.user.fullName }}</p>

<div class="row mt-4">
    <div class="col-md-4 mb-4">
        <div class="card h-100">
            <div class="card-body text-center">
                <h3 class="display-4">{{ reservations|length }}</h3>
                <p class="text-muted">Réservation(s)</p>
                <a href="{{ path('app_profile_reservations') }}" class="btn btn-outline-primary btn-sm">Voir mes réservations</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="card h-100">
            <div class="card-body text-center">
                <h3 class="display-4">{{ favorites|length }}</h3>
                <p class="text-muted">Favori(s)</p>
                <a href="{{ path('app_profile_favorites') }}" class="btn btn-outline-primary btn-sm">Voir mes favoris</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="card h-100">
            <div class="card-body text-center">
                <h3 class="display-4">{{ app.user.reviews|length }}</h3>
                <p class="text-muted">Avis publié(s)</p>
                <a href="{{ path('app_book_index') }}" class="btn btn-outline-primary btn-sm">Parcourir le catalogue</a>
            </div>
        </div>
    </div>
</div>

{% if reservations|length > 0 %}
<h3 class="mt-4">Dernières réservations</h3>
<div class="table-responsive">
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Livre</th>
                <th>Du</th>
                <th>Au</th>
                <th>Statut</th>
            </tr>
        </thead>
        <tbody>
            {% for reservation in reservations|slice(0, 5) %}
                <tr>
                    <td><a href="{{ path('app_book_show', {slug: reservation.book.slug}) }}">{{ reservation.book.title }}</a></td>
                    <td>{{ reservation.startDate|date('d/m/Y') }}</td>
                    <td>{{ reservation.endDate|date('d/m/Y') }}</td>
                    <td><span class="badge {{ reservation.statusBadgeClass }}">{{ reservation.statusLabel }}</span></td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endif %}
{% endblock %}
