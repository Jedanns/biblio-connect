{% extends 'base.html.twig' %}

{% block title %}Administration - BiblioConnect{% endblock %}

{% block body %}
<h1>Administration</h1>

<div class="row mt-4 mb-4">
    <div class="col-md-3">
        <div class="card stat-card" style="border-left-color: #0d6efd;">
            <div class="card-body">
                <h5 class="text-muted">Livres</h5>
                <h2>{{ totalBooks }}</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card" style="border-left-color: #198754;">
            <div class="card-body">
                <h5 class="text-muted">Utilisateurs</h5>
                <h2>{{ totalUsers }}</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card" style="border-left-color: #ffc107;">
            <div class="card-body">
                <h5 class="text-muted">Réservations en attente</h5>
                <h2>{{ pendingReservations|length }}</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card" style="border-left-color: #dc3545;">
            <div class="card-body">
                <h5 class="text-muted">Avis à modérer</h5>
                <h2>{{ unapprovedReviews|length }}</h2>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-3 mb-3">
        <a href="{{ path('app_admin_users') }}" class="btn btn-outline-primary w-100 py-3">Gérer les utilisateurs</a>
    </div>
    <div class="col-md-3 mb-3">
        <a href="{{ path('app_admin_reviews') }}" class="btn btn-outline-danger w-100 py-3">Modérer les avis</a>
    </div>
    <div class="col-md-3 mb-3">
        <a href="{{ path('app_admin_stock') }}" class="btn btn-outline-warning w-100 py-3">Suivi des stocks</a>
    </div>
    <div class="col-md-3 mb-3">
        <a href="{{ path('app_admin_reservations') }}" class="btn btn-outline-success w-100 py-3">Réservations globales</a>
    </div>
</div>

<div class="row mt-3">
    <div class="col-md-3 mb-3">
        <a href="{{ path('app_librarian_books') }}" class="btn btn-outline-secondary w-100 py-3">Catalogue livres</a>
    </div>
    <div class="col-md-3 mb-3">
        <a href="{{ path('app_librarian_authors') }}" class="btn btn-outline-secondary w-100 py-3">Gérer auteurs</a>
    </div>
    <div class="col-md-3 mb-3">
        <a href="{{ path('app_librarian_categories') }}" class="btn btn-outline-secondary w-100 py-3">Gérer catégories</a>
    </div>
</div>
{% endblock %}
