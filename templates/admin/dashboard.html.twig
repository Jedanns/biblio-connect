{% extends 'base.html.twig' %}

{% block title %}Administration — BiblioConnect{% endblock %}

{% block body %}
<span class="editorial-label">Panneau d'administration</span>
<h1 class="mt-2">Administration</h1>
<hr class="editorial-divider">

<div class="row g-4 mb-5">
    <div class="col-md-3">
        <div class="card stat-card">
            <div class="card-body p-3">
                <div class="stat-label">Livres</div>
                <div class="stat-number mt-1">{{ totalBooks }}</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card" style="border-left-color: var(--color-success);">
            <div class="card-body p-3">
                <div class="stat-label">Utilisateurs</div>
                <div class="stat-number mt-1">{{ totalUsers }}</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card" style="border-left-color: var(--color-warning);">
            <div class="card-body p-3">
                <div class="stat-label">Réservations en attente</div>
                <div class="stat-number mt-1">{{ pendingReservations|length }}</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card" style="border-left-color: var(--color-danger);">
            <div class="card-body p-3">
                <div class="stat-label">Avis à modérer</div>
                <div class="stat-number mt-1">{{ unapprovedReviews|length }}</div>
            </div>
        </div>
    </div>
</div>

<span class="editorial-label">Actions rapides</span>
<h3 class="mt-2">Gestion</h3>
<hr class="editorial-divider">

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <a href="{{ path('app_admin_users') }}" class="action-card">
            <div class="action-title">Utilisateurs</div>
            <div class="action-desc">Gérer les comptes et rôles</div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="{{ path('app_admin_reviews') }}" class="action-card">
            <div class="action-title">Modération</div>
            <div class="action-desc">Avis en attente d'approbation</div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="{{ path('app_admin_stock') }}" class="action-card">
            <div class="action-title">Stocks</div>
            <div class="action-desc">Suivi des exemplaires</div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="{{ path('app_admin_reservations') }}" class="action-card">
            <div class="action-title">Réservations</div>
            <div class="action-desc">Historique global</div>
        </a>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-3">
        <a href="{{ path('app_librarian_books') }}" class="action-card">
            <div class="action-title">Catalogue</div>
            <div class="action-desc">Gérer les livres</div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="{{ path('app_librarian_authors') }}" class="action-card">
            <div class="action-title">Auteurs</div>
            <div class="action-desc">Gérer les auteurs</div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="{{ path('app_librarian_categories') }}" class="action-card">
            <div class="action-title">Catégories</div>
            <div class="action-desc">Gérer les catégories</div>
        </a>
    </div>
</div>
{% endblock %}
