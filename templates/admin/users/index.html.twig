{% extends 'base.html.twig' %}

{% block title %}Gestion des utilisateurs - BiblioConnect{% endblock %}

{% block body %}
<h1>Gestion des utilisateurs</h1>

<div class="table-responsive">
    <table class="table table-hover">
        <thead>
            <tr><th>Nom</th><th>Email</th><th>Rôles</th><th>Actif</th><th>Inscrit le</th><th>Actions</th></tr>
        </thead>
        <tbody>
            {% for user in users %}
                <tr>
                    <td>{{ user.fullName }}</td>
                    <td>{{ user.email }}</td>
                    <td>
                        {% for role in user.roles %}
                            {% if role == 'ROLE_ADMIN' %}
                                <span class="badge bg-danger">Admin</span>
                            {% elseif role == 'ROLE_LIBRARIAN' %}
                                <span class="badge bg-warning text-dark">Bibliothécaire</span>
                            {% elseif role == 'ROLE_USER' %}
                                <span class="badge bg-primary">Utilisateur</span>
                            {% endif %}
                        {% endfor %}
                    </td>
                    <td>
                        {% if user.isActive %}
                            <span class="text-success">Oui</span>
                        {% else %}
                            <span class="text-danger">Non</span>
                        {% endif %}
                    </td>
                    <td>{{ user.createdAt|date('d/m/Y') }}</td>
                    <td>
                        <a href="{{ path('app_admin_user_edit', {id: user.id}) }}" class="btn btn-sm btn-outline-primary">Modifier</a>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
