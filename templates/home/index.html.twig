{% extends 'base.html.twig' %}

{% block title %}BiblioConnect - Votre bibliothèque en ligne{% endblock %}

{% block body %}
<section class="hero rounded-3 mb-5">
    <div class="text-center">
        <h1 class="display-4 fw-bold">Bienvenue sur BiblioConnect</h1>
        <p class="lead mt-3">Votre plateforme de gestion de bibliothèque en ligne</p>
        <div class="mt-4">
            <a href="{{ path('app_book_index') }}" class="btn btn-light btn-lg me-2">Parcourir le catalogue</a>
            {% if not app.user %}
                <a href="{{ path('app_register') }}" class="btn btn-outline-light btn-lg">Créer un compte</a>
            {% endif %}
        </div>
        <p class="mt-3 opacity-75">{{ totalBooks }} ouvrages disponibles</p>
    </div>
</section>

{% if latestBooks|length > 0 %}
<section>
    <h2 class="mb-4">Derniers ajouts</h2>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
        {% for book in latestBooks %}
            <div class="col">
                {% include '_partials/_book_card.html.twig' with {book: book} %}
            </div>
        {% endfor %}
    </div>
    <div class="text-center mt-4">
        <a href="{{ path('app_book_index') }}" class="btn btn-outline-primary">Voir tout le catalogue</a>
    </div>
</section>
{% endif %}
{% endblock %}
