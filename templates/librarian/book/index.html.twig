{% extends 'base.html.twig' %}

{% block title %}Gestion des livres - BiblioConnect{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Gestion des livres</h1>
    <a href="{{ path('app_librarian_book_new') }}" class="btn btn-primary">Ajouter un livre</a>
</div>

<div class="table-responsive">
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Titre</th>
                <th>Auteur</th>
                <th>Catégories</th>
                <th>Stock</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for book in books %}
                <tr>
                    <td>
                        <a href="{{ path('app_book_show', {slug: book.slug}) }}">{{ book.title }}</a>
                    </td>
                    <td>{{ book.author }}</td>
                    <td>
                        {% for cat in book.categories %}
                            <span class="badge bg-secondary">{{ cat.name }}</span>
                        {% endfor %}
                    </td>
                    <td>
                        <span class="{{ book.availableCopies > 0 ? 'text-success' : 'text-danger' }}">
                            {{ book.availableCopies }}/{{ book.totalCopies }}
                        </span>
                    </td>
                    <td>
                        <a href="{{ path('app_librarian_book_edit', {id: book.id}) }}" class="btn btn-sm btn-outline-primary">Modifier</a>
                        <form method="post" action="{{ path('app_librarian_book_delete', {id: book.id}) }}" class="d-inline"
                              onsubmit="return confirm('Supprimer ce livre ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ book.id) }}">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Supprimer</button>
                        </form>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
