{% extends 'base.html.twig' %}

{% block title %}Ajouter un livre - BiblioConnect{% endblock %}

{% block body %}
<h1>Ajouter un livre</h1>

<div class="card">
    <div class="card-body">
        {{ form_start(form) }}
            <div class="row">
                <div class="col-md-8">{{ form_row(form.title) }}</div>
                <div class="col-md-4">{{ form_row(form.isbn) }}</div>
            </div>
            {{ form_row(form.description) }}
            <div class="row">
                <div class="col-md-4">{{ form_row(form.author) }}</div>
                <div class="col-md-4">{{ form_row(form.language) }}</div>
                <div class="col-md-4">{{ form_row(form.coverImageFile) }}</div>
            </div>
            <div class="row">
                <div class="col-md-4">{{ form_row(form.publicationDate) }}</div>
                <div class="col-md-4">{{ form_row(form.pageCount) }}</div>
                <div class="col-md-4">{{ form_row(form.totalCopies) }}</div>
            </div>
            {{ form_row(form.categories) }}
            <button type="submit" class="btn btn-primary">Ajouter</button>
            <a href="{{ path('app_librarian_books') }}" class="btn btn-outline-secondary ms-2">Annuler</a>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
