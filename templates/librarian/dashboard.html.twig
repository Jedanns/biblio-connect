{% extends 'base.html.twig' %}

{% block title %}Espace Bibliothécaire — BiblioConnect{% endblock %}

{% block body %}
<span class="editorial-label">Espace bibliothécaire</span>
<h1 class="mt-2">Tableau de bord</h1>
<hr class="editorial-divider">

<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="card stat-card">
            <div class="card-body p-3">
                <div class="stat-label">Livres au catalogue</div>
                <div class="stat-number mt-1">{{ totalBooks }}</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card" style="border-left-color: var(--color-warning);">
            <div class="card-body p-3">
                <div class="stat-label">Réservations en attente</div>
                <div class="stat-number mt-1">{{ pendingReservations|length }}</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-5">
    <div class="col-md-4">
        <a href="{{ path('app_librarian_books') }}" class="action-card">
            <div class="action-title">Livres</div>
            <div class="action-desc">Gérer le catalogue de livres</div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="{{ path('app_librarian_authors') }}" class="action-card">
            <div class="action-title">Auteurs</div>
            <div class="action-desc">Gérer les auteurs du catalogue</div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="{{ path('app_librarian_categories') }}" class="action-card">
            <div class="action-title">Catégories</div>
            <div class="action-desc">Gérer les catégories</div>
        </a>
    </div>
</div>

{% if pendingReservations|length > 0 %}
<span class="editorial-label">En attente</span>
<h3 class="mt-2">Réservations à traiter</h3>
<hr class="editorial-divider">
<div class="table-responsive">
    <table class="table table-editorial">
        <thead><tr><th>Utilisateur</th><th>Livre</th><th>Du</th><th>Au</th><th>Réservé le</th></tr></thead>
        <tbody>
            {% for r in pendingReservations %}
                <tr>
                    <td>{{ r.user.fullName }}</td>
                    <td>{{ r.book.title }}</td>
                    <td>{{ r.startDate|date('d/m/Y') }}</td>
                    <td>{{ r.endDate|date('d/m/Y') }}</td>
                    <td>{{ r.reservedAt|date('d/m/Y H:i') }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endif %}
{% endblock %}
