{% extends 'base.html.twig' %}

{% block title %}Gestion des catégories - BiblioConnect{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Gestion des catégories</h1>
    <a href="{{ path('app_librarian_category_new') }}" class="btn btn-primary">Ajouter une catégorie</a>
</div>

<div class="table-responsive">
    <table class="table table-hover">
        <thead><tr><th>Nom</th><th>Livres</th><th>Actions</th></tr></thead>
        <tbody>
            {% for category in categories %}
                <tr>
                    <td>{{ category.name }}</td>
                    <td>{{ category.books|length }}</td>
                    <td>
                        <a href="{{ path('app_librarian_category_edit', {id: category.id}) }}" class="btn btn-sm btn-outline-primary">Modifier</a>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
