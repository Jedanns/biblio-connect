{% extends 'base.html.twig' %}

{% block title %}Historique des réservations - BiblioConnect{% endblock %}

{% block body %}
<h1>Historique des réservations</h1>

<div class="table-responsive">
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Utilisateur</th>
                <th>Livre</th>
                <th>Du</th>
                <th>Au</th>
                <th>Statut</th>
                <th>Réservé le</th>
            </tr>
        </thead>
        <tbody>
            {% for r in reservations %}
                <tr>
                    <td>{{ r.user.fullName }}</td>
                    <td>{{ r.book.title }}</td>
                    <td>{{ r.startDate|date('d/m/Y') }}</td>
                    <td>{{ r.endDate|date('d/m/Y') }}</td>
                    <td><span class="badge {{ r.statusBadgeClass }}">{{ r.statusLabel }}</span></td>
                    <td>{{ r.reservedAt|date('d/m/Y H:i') }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
