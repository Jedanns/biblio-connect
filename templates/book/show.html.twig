{% extends 'base.html.twig' %}

{% block title %}{{ book.title }} — BiblioConnect{% endblock %}

{% block body %}
<a href="{{ path('app_book_index') }}" class="btn btn-editorial-ghost mb-4" style="font-size: 0.85rem;">
    <span style="margin-right: 0.5rem;">&larr;</span> Retour au catalogue
</a>

<div class="row g-5">
    <div class="col-lg-5">
        <div class="book-detail-cover">
            {% if book.coverImage %}
                <img src="{{ asset('uploads/covers/' ~ book.coverImage) }}" alt="{{ book.title }}">
            {% else %}
                <span style="font-size: 6rem; opacity: 0.3;">📖</span>
            {% endif %}
        </div>
    </div>

    <div class="col-lg-7">
        <span class="editorial-label">{{ book.language.name }}</span>
        <h1 class="mt-2" style="font-size: 2.2rem;">{{ book.title }}</h1>
        <p style="font-family: var(--font-display); font-style: italic; font-size: 1.15rem; color: var(--color-text-soft);">
            par {{ book.author.fullName }}
        </p>

        {% if book.averageRating %}
            <div class="mb-3">
                {% include '_partials/_star_rating.html.twig' with {rating: book.averageRating} %}
                <span class="text-muted ms-2" style="font-size: 0.85rem;">({{ book.approvedReviews|length }} avis)</span>
            </div>
        {% endif %}

        <div class="mb-4">
            {% for category in book.categories %}
                <span class="tag me-1">{{ category.name }}</span>
            {% endfor %}
        </div>

        <hr class="editorial-divider">

        <div style="max-width: 380px;">
            {% if book.isbn %}
                <div class="book-meta-item">
                    <span class="book-meta-label">ISBN</span>
                    <span>{{ book.isbn }}</span>
                </div>
            {% endif %}
            {% if book.publicationDate %}
                <div class="book-meta-item">
                    <span class="book-meta-label">Publication</span>
                    <span>{{ book.publicationDate|date('d/m/Y') }}</span>
                </div>
            {% endif %}
            {% if book.pageCount %}
                <div class="book-meta-item">
                    <span class="book-meta-label">Pages</span>
                    <span>{{ book.pageCount }}</span>
                </div>
            {% endif %}
            <div class="book-meta-item" style="border-bottom: none;">
                <span class="book-meta-label">Disponibilité</span>
                {% if book.availableCopies > 0 %}
                    <span class="availability-tag available">{{ book.availableCopies }}/{{ book.totalCopies }}</span>
                {% else %}
                    <span class="availability-tag unavailable">Indisponible</span>
                {% endif %}
            </div>
        </div>

        {% if book.description %}
            <div class="mt-4">
                <span class="editorial-label">Synopsis</span>
                <p class="mt-2" style="line-height: 1.8; color: var(--color-text-soft);">{{ book.description|nl2br }}</p>
            </div>
        {% endif %}

        <div class="mt-4 d-flex gap-3">
            {% if app.user %}
                {% if book.availableCopies > 0 %}
                    <a href="{{ path('app_reservation_new', {id: book.id}) }}" class="btn btn-editorial btn-editorial-primary">Réserver cet ouvrage</a>
                {% endif %}
                <form method="post" action="{{ path('app_favorite_toggle', {id: book.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('favorite' ~ book.id) }}">
                    <button type="submit" class="btn btn-editorial {{ isFavorited ? 'btn-editorial-accent' : 'btn-editorial-outline' }}">
                        {{ isFavorited ? 'Retirer des favoris' : 'Mettre en favori' }}
                    </button>
                </form>
            {% else %}
                <a href="{{ path('app_login') }}" class="btn btn-editorial btn-editorial-outline">Se connecter pour réserver</a>
            {% endif %}
        </div>
    </div>
</div>

{# --- Reviews Section --- #}
<div class="mt-5 pt-4" style="border-top: 1px solid var(--color-border-light);">
    <span class="editorial-label">Lecteurs</span>
    <h2 class="mt-2">Avis</h2>
    <hr class="editorial-divider">

    {% if app.user and not hasReviewed %}
        <div class="review-card mb-4" style="border-left: 3px solid var(--color-accent);">
            <span class="editorial-label mb-3 d-block">Votre avis</span>
            <form method="post" action="{{ path('app_review_new', {bookId: book.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('review' ~ book.id) }}">
                <div class="mb-3">
                    <label class="form-label">Note</label>
                    <div class="star-rating" style="font-size: 1.3rem;">
                        {% for i in 1..5 %}
                            <label style="cursor: pointer; margin-right: 0.25rem;">
                                <input type="radio" name="rating" value="{{ i }}" style="display: none;" {{ i == 5 ? 'checked' : '' }} required>
                                <span>{{ i }} &#9733;</span>
                            </label>
                        {% endfor %}
                    </div>
                </div>
                <div class="mb-3">
                    <label for="comment" class="form-label">Commentaire (optionnel)</label>
                    <textarea name="comment" id="comment" class="form-control" rows="3" maxlength="2000" placeholder="Partagez votre ressenti..."></textarea>
                </div>
                <button type="submit" class="btn btn-editorial btn-editorial-primary">Publier</button>
            </form>
        </div>
    {% endif %}

    {% set approvedReviews = book.approvedReviews %}
    {% if approvedReviews|length > 0 %}
        {% for review in approvedReviews %}
            <div class="review-card">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="review-author">{{ review.user.fullName }}</span>
                        <span class="review-date ms-2">{{ review.createdAt|date('d/m/Y') }}</span>
                    </div>
                    {% include '_partials/_star_rating.html.twig' with {rating: review.rating} %}
                </div>
                {% if review.comment %}
                    <p class="review-comment">{{ review.comment|nl2br }}</p>
                {% endif %}
            </div>
        {% endfor %}
    {% else %}
        <p class="text-muted" style="font-style: italic;">Aucun avis pour le moment. Soyez le premier !</p>
    {% endif %}
</div>
{% endblock %}
