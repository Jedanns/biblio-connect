{% extends 'base.html.twig' %}

{% block title %}Catalogue — BiblioConnect{% endblock %}

{% block body %}
<span class="editorial-label">Collection</span>
<h1 class="mt-2">Catalogue</h1>
<hr class="editorial-divider">

<div class="search-bar mb-4">
    {{ form_start(searchForm, {'attr': {'class': 'row g-3 align-items-end'}}) }}
        <div class="col-md-4">
            {{ form_row(searchForm.query) }}
        </div>
        <div class="col-md-3">
            {{ form_row(searchForm.category) }}
        </div>
        <div class="col-md-3">
            {{ form_row(searchForm.author) }}
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-editorial btn-editorial-primary w-100">Rechercher</button>
        </div>
    {{ form_end(searchForm) }}
</div>

{% if books|length > 0 %}
    <p class="text-muted mb-4" style="font-size: 0.85rem;">{{ books|length }} résultat{{ books|length > 1 ? 's' : '' }}</p>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
        {% for book in books %}
            <div class="col">
                {% include '_partials/_book_card.html.twig' with {book: book} %}
            </div>
        {% endfor %}
    </div>
{% else %}
    <div class="text-center py-5">
        <p class="text-muted" style="font-size: 1.1rem;">Aucun ouvrage ne correspond à votre recherche.</p>
        <a href="{{ path('app_book_index') }}" class="btn btn-editorial btn-editorial-outline mt-2">Réinitialiser</a>
    </div>
{% endif %}
{% endblock %}
